{
  "name": "pub-api",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "dev": "nodemon --watch src --ext ts,json --exec \"ts-node src/server.ts\"",
    "prisma:generate": "prisma generate",
    "postinstall": "yarn prisma:generate",
    "build": "yarn prisma:generate && tsc",
    "start": "prisma migrate deploy && node dist/server.js",
    "import:pubs": "ts-node --project tsconfig.scripts.json scripts/import-pubs.ts",
    "reset:pubs": "ts-node --project tsconfig.scripts.json scripts/reset-pubs.ts",
    "reset:pubs:and:import": "ts-node --project tsconfig.scripts.json scripts/reset-pubs.ts && ts-node --project tsconfig.scripts.json scripts/fetch-pubs-overpass.ts",
    "import:pubs:from-csv": "ts-node --project tsconfig.scripts.json scripts/import-pubs-csv.ts",
    "import:pubs:overpass": "ts-node --project tsconfig.scripts.json scripts/fetch-pubs-overpass.ts",
    "import:pubs:overpass:csv": "ts-node --project tsconfig.scripts.json scripts/fetch-pubs-overpass.ts --csv",
    "import:pubs:uk-cities": "ts-node --project tsconfig.scripts.json scripts/fetch-pubs-uk-cities.ts",
    "import:pubs:uk-cities:csv": "ts-node --project tsconfig.scripts.json scripts/fetch-pubs-uk-cities.ts --csv",
    "import:pubs:fsa": "ts-node --project tsconfig.scripts.json scripts/fetch-pubs-fsa.ts",
    "import:pubs:fsa:csv": "ts-node --project tsconfig.scripts.json scripts/fetch-pubs-fsa.ts --csv",
    "test": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest --watch",
    "ts-check": "yarn prisma:generate && tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "lint:errors": "biome check . | findstr error"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "engines": {
    "node": ">=22.12.0"
  },
  "packageManager": "yarn@1.22.22",
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.0.0",
    "@prisma/client": "^7.0.0",
    "bcrypt": "^6.0.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.1",
    "express": "^5.1.0",
    "express-rate-limit": "^8.4.1",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.16.3",
    "prisma": "^7.0.0",
    "resend": "^6.0.0",
    "stripe": "^22.0.0",
    "zod": "^4.0.5"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.16",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/helmet": "^4.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^24.0.13",
    "@types/supertest": "^7.0.0",
    "@vitest/coverage-v8": "4.1.7",
    "knip": "^6.0.0",
    "nodemon": "3.1.14",
    "supertest": "^7.2.2",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "6.0.3",
    "vitest": "^4.0.18"
  }
}
