# Core server
PORT=4000
JWT_SECRET=replace-with-a-long-random-secret

# Database (Prisma)
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE

# Email (Resend)
RESEND_API_KEY=re_replace_with_resend_api_key

# Public URLs
# Frontend app base URL used for password reset links and Stripe redirects
FRONTEND_URL=http://localhost:3000
# Backend API base URL used for email verification links
API_BASE_URL=http://localhost:4000
# Optional legacy alias used by verification email fallback
BACKEND_URL=http://localhost:4000

# Stripe
STRIPE_SECRET_KEY=sk_test_replace_with_stripe_secret_key
# Optional: used by raw Stripe fetch calls when you need a pinned API version
# STRIPE_API_VERSION=2024-06-20
