generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pub {
  id           String   @id @default(cuid())
  name         String
  city         String
  address      String
  postcode     String
  country      String?
  lat          Float?
  lng          Float?
  website      String?
  description  String?
  imageUrl     String?
  tags         String[]
  createdAt    DateTime @default(now())
  operator     String?
  area         String?
  phone        String?
  borough      String?
  openingHours Json?
}

model User {
  id                                           String              @id @default(cuid())
  name                                         String?
  username                                     String?             @unique
  email                                        String?             @unique
  image                                        String?
  approved                                     Boolean             @default(false)
  admin                                        Boolean             @default(false)
  verificationExpiry                           DateTime?
  verificationToken                            String?
  emailVerified                                Boolean             @default(false)
  resetExpiry                                  DateTime?
  resetToken                                   String?
  
  // Subscription fields
  subscriptionTier                             ApiKeyTier          @default(HOBBY)
  subscriptionStatus                           SubscriptionStatus  @default(INACTIVE)
  stripeCustomerId                             String?             @unique
  stripeSubscriptionId                         String?             @unique
  subscriptionStartDate                        DateTime?
  subscriptionEndDate                          DateTime?
  
  accounts                                     Account[]
  apiKeys                                      ApiKey[]
  ApiKeyRequest_ApiKeyRequest_reviewedByToUser ApiKeyRequest[]     @relation("ApiKeyRequest_reviewedByToUser")
  ApiKeyRequest_ApiKeyRequest_userIdToUser     ApiKeyRequest[]     @relation("ApiKeyRequest_userIdToUser")
  auditLogs                                    AuditLog[]
  sessions                                     Session[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id])

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(cuid())
  action    String
  entity    String
  entityId  String
  userId    String?
  timestamp DateTime @default(now())
  oldValues Json?
  newValues Json?
  ipAddress String?
  userAgent String?
  user      User?    @relation(fields: [userId], references: [id])
}

model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique
  keyPrefix   String
  userId      String
  tier        ApiKeyTier @default(HOBBY)
  // Operational key lifecycle status
  keyStatus   KeyStatus @default(ACTIVE)
  rateLimit   Int       @default(1000)
  usageCount  Int       @default(0)
  lastUsed    DateTime?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  expiresAt   DateTime?
  permissions String[]  @default(["read:pubs"])
  
  // New tier-based rate limiting
  requestsPerHour   Int @default(100)
  requestsPerDay    Int @default(1000)
  requestsPerMonth  Int @default(10000)
  currentMonthUsage Int @default(0)
  monthlyResetDate  DateTime @default(now())
  
  user        User      @relation(fields: [userId], references: [id])
  usage       ApiKeyUsage[]

  @@index([keyHash])
  @@index([userId])
}

model ApiKeyRequest {
  id                                  String    @id
  userId                              String
  businessName                        String
  useCase                             String
  estimatedUsage                      Int
  contactEmail                        String?
  status                              String    @default("PENDING")
  createdAt                           DateTime  @default(now())
  reviewedAt                          DateTime?
  reviewedBy                          String?
  adminNotes                          String?
  User_ApiKeyRequest_reviewedByToUser User?     @relation("ApiKeyRequest_reviewedByToUser", fields: [reviewedBy], references: [id])
  User_ApiKeyRequest_userIdToUser     User      @relation("ApiKeyRequest_userIdToUser", fields: [userId], references: [id])

  @@index([status])
  @@index([userId])
}

model ApiKeyUsage {
  id            String   @id @default(cuid())
  apiKeyId      String
  timestamp     DateTime @default(now())
  endpoint      String
  method        String
  statusCode    Int
  responseTime  Int?
  ipAddress     String?
  userAgent     String?
  
  apiKey ApiKey @relation(fields: [apiKeyId], references: [id])
  
  @@index([apiKeyId, timestamp])
  @@index([timestamp])
}

enum ApiKeyTier {
  HOBBY        // Limited access for hobby projects
  DEVELOPER    // Single developer with reasonable access
  BUSINESS     // Small business with higher limits
}

enum SubscriptionStatus {
  INACTIVE     // No active subscription
  ACTIVE       // Active subscription
  PAST_DUE     // Payment failed, grace period
  CANCELLED    // User cancelled subscription
  INCOMPLETE   // Subscription created but payment not completed
  TRIALING     // In trial period
}

enum KeyStatus {
  ACTIVE
  SCHEDULED_EXPIRE
  EXPIRED
  REVOKED
}
