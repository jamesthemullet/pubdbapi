// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pub {
  id          String   @id @default(cuid())
  name        String
  city        String
  address     String
  postcode    String
  lat         Float
  lng         Float
  website     String?
  description String?
  imageUrl    String?
  tags        String[]
  createdAt   DateTime @default(now())
}